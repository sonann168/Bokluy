# ── Required ──────────────────────────────────────────────────────────────────
PORT=8080
SESSION_SECRET=change-me-to-a-random-32-char-string

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://imuzaki:password@localhost:5432/imuzaki_db

# ── ABA PayWay (leave blank to run in sandbox/auto-success mode) ──────────────
PAYWAY_MERCHANT_ID=
PAYWAY_API_KEY=
PAYWAY_API_SECRET=
PAYWAY_RETURN_URL=https://yourdomain.com

# ── Docker Compose (only used by docker-compose.yml) ─────────────────────────
POSTGRES_DB=imuzaki_db
POSTGRES_USER=imuzaki
POSTGRES_PASSWORD=change-me
